# ═══════════════════════════════════════════════════════
#  FitAgent — Environment Variables
#  Copy: cp .env.example .env  then fill in all values.
# ═══════════════════════════════════════════════════════

# ── AI ──────────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=changeme
DB_NAME=fitness_ai
# In Docker Compose the DATABASE_URL is overridden automatically to use the
# internal service name "db". For local dev set it to localhost:
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/fitness_ai

# ── Google OAuth 2.0 ────────────────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URIs:
#      Local:      http://localhost:8000/api/auth/callback
#      Production: https://<your-fastapi-domain>/api/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Explicit OAuth callback URI sent to Google.
# MUST match exactly what is whitelisted in Google Cloud Console.
# If set, takes priority over FASTAPI_BASE_URL + /api/auth/callback.
# Production: https://<your-fastapi-domain>/api/auth/callback
# Local:      http://localhost:8000/api/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── Auth / Sessions ──────────────────────────────────────────────────────────
# Shared between FastAPI (signs JWT) and Express (verifies JWT).
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Production: add your Vercel frontend URL, e.g. https://fitagent-ten.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Service URLs ─────────────────────────────────────────────────────────────
# Internal server-to-server URL (Express → FastAPI, overridden in Docker Compose)
FASTAPI_URL=http://localhost:8000
# PUBLIC URL of FastAPI visible to the browser (used for OAuth redirect button)
# Production: https://<your-fastapi-domain>
FASTAPI_BASE_URL=http://localhost:8000
# PUBLIC URL of the frontend (FastAPI redirects here after OAuth)
# Production: https://fitagent-ten.vercel.app
FRONTEND_URL=http://localhost:3000
