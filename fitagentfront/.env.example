# ── FastAPI backend ───────────────────────────────────────────────────────────
# Server-to-server URL (Vercel → Railway). Used by tRPC procedures.
# Production: https://fitnessai-production-1346.up.railway.app
# Docker:     http://api:8000
FASTAPI_URL=https://fitnessai-production-1346.up.railway.app

# PUBLIC URL of FastAPI — browser-visible, used for OAuth start redirect.
# Usually the same as FASTAPI_URL for Railway deployments.
FASTAPI_BASE_URL=https://fitnessai-production-1346.up.railway.app

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match JWT_SECRET in the Railway backend service exactly.
# Generate: openssl rand -hex 32
JWT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of this Vercel deployment. Used for OAuth finish redirect.
# Vercel also sets VERCEL_URL automatically, but FRONTEND_URL takes priority.
FRONTEND_URL=https://fitagent-ten.vercel.app
